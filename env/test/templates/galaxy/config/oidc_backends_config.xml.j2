    <provider name="google">
        <client_id>{{ galaxy_google_client_id }}</client_id>
        <client_secret>{{ galaxy_google_client_secret }}</client_secret>
        <redirect_uri>https://test.galaxyproject.org/authnz/google/callback</redirect_uri>
        <icon>https://developers.google.com/identity/images/btn_google_signin_light_normal_web.png</icon>
        <prompt>consent</prompt>
    </provider>
    <!--
    Keycloak (auth.usegalaxy.org), "galaxy-test" realm. Authenticates against
    Galaxy accounts via the realm's user-storage federation. <url> is the realm
    base; Galaxy appends /.well-known/openid-configuration. The client
    (galaxy-api) and its secret are provisioned in the infrastructure-playbook
    keycloak role; the secret here must match its
    vault_keycloak_galaxy_api_test_client_secret.
    -->
    <provider name="keycloak">
        <url>https://auth.usegalaxy.org/realms/galaxy-test</url>
        <client_id>{{ galaxy_keycloak_client_id }}</client_id>
        <client_secret>{{ galaxy_keycloak_client_secret }}</client_secret>
        <redirect_uri>https://test.galaxyproject.org/authnz/keycloak/callback</redirect_uri>
    </provider>
</OIDC>
