#!/bin/sh

password_path="${VAULT_PASSWORD_PATH:=ansible/vault/usegalaxy}"
if [ -n "${VAULT_PASSWORD_STORE_DIR:-}" ]; then
    PASSWORD_STORE_DIR="$VAULT_PASSWORD_STORE_DIR"
    export PASSWORD_STORE_DIR
fi

# Pick the password manager: honour an explicit override, otherwise prefer
# gopass when it is installed and fall back to pass.
pass_cmd="${VAULT_PASS_CMD:-}"
if [ -z "$pass_cmd" ]; then
    if command -v gopass >/dev/null 2>&1; then
        pass_cmd="gopass"
    else
        pass_cmd="pass"
    fi
fi

if [ "$pass_cmd" = "gopass" ]; then
    # The secret lives in a gopass substore, addressed by prefixing its
    # mount name to the path. gopass prints only the secret with `show -o`.
    gopass_store="${VAULT_GOPASS_STORE:-galaxy}"
    pass=$(gopass show -o "${gopass_store}/${password_path}")
else
    pass=$($pass_cmd "$password_path" | head -1)
fi

if [ $? -ne 0 ]; then
    echo -n 'VAULT Password: ' >&2
    stty -echo
    read pass
    stty echo
    echo '' >&2
fi

echo "$pass"
